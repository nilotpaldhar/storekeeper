		"commitizen": "^4.2.5",
		"eslint": "^8.28.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-next": "^13.0.4",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-react": "^7.31.11",
		"husky": "^8.0.2",
		"prettier": "^2.8.0",
		"rimraf": "^3.0.2"
	}
}
